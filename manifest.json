{
    "manifest_version": 3,
    "name": "DocLaunch",
    "version": "1.0",

    "permissions": [
        "storage",
        "activeTab"
    ],

    "host_permissions": [
        "https://*.instructure.com/*",
        "https://docs.google.com/*",
        "https://www.office.com/*"
    ],

    "background": {
        "service_worker": "js/background.js"
    },

    "content_scripts": [
        {
            "matches": [
                "https://*.instructure.com/courses/*/assignments/*",
                "https://*.canvaslms.com/courses/*/assignments/*"
            ],
            "js": ["js/main.js"],
            "run_at": "document_idle"
        }
    ],

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },

    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}